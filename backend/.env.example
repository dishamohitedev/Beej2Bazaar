# --- App ---
ENV=development
JWT_SECRET=change_this_to_a_long_random_secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Database (leave MONGO_URI empty to use in-memory mock store for local dev) ---
MONGO_URI=
MONGO_DB_NAME=beejbazaar

# --- Firebase (leave empty to use mock OTP: any phone, OTP is always 123456) ---
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_JSON=

# --- Cloudinary (Module 4+, not needed for auth) ---
CLOUDINARY_URL=

# --- Gemini (Module 4/13+, not needed for auth) ---
GEMINI_API_KEY=

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:5173
